# Required
OPENROUTER_API_KEY=
BITGN_API_KEY=

# Model & benchmark
# Default is the leaderboard champion model (run-22RxPyYQ4dtnsaeKdXpRsJ6ce, top-20
# bitgn/ecom1-prod): a single open-weight model, no planner/router/judge.
MODEL_ID=xiaomi/mimo-v2.5-pro
# BENCH_ID=bitgn/ecom1-dev
# BITGN_HOST=https://api.bitgn.com

# Run control
# MIN_TASKS / MAX_TASKS are INCLUSIVE numeric bounds on the task index (t05 → 5).
# Examples:
#   MIN_TASKS=5  MAX_TASKS=10   → run t05..t10
#   MAX_TASKS=10                → run t01..t10
#   MIN_TASKS=40                → run t40..end
# argv overrides the range: `bun run main.ts t13 t38` runs only those two.
# tasksState.ts `enabled: false` still skips a task even if it's in range.
MIN_TASKS=
MAX_TASKS=
CONCURRENCY=3
HINT=

# OpenRouter
OPENROUTER_TIMEOUT_MS=90000

# How long to wait for BitGN's grader after submitRun (ms). 5 min default.
SCORE_POLL_TIMEOUT_MS=300000

# Web UI port, 0 to disable
WEB_PORT=3000

# Feature flags. The defaults below reproduce the leaderboard CHAMPION config
# (run-22RxPyYQ4dtnsaeKdXpRsJ6ce — local 20260530-114102-65eb5b, effort=low):
# LAZY_MD + AUTO_CITE + STRICT_REFS + REFS_WHY_CANONICAL + CITING_REASONING +
# STRUCTURED_FACTS + DEBUG_REF_PROBE all ON, NAV_HINTS OFF. To bisect, flip one
# back to "false" at a time. DEBUG_REF_PROBE is diagnostic only (adds find() RPCs)
# and is safe to turn off without changing behavior.
# FEAT_LAZY_MD: workspace-md-index block + auto-preload .md surfaced by tool output (up to 50KB/turn)
# FEAT_AUTO_CITE: auto-push every successful read (and preloaded path) into scratchpad.refs
# FEAT_STRICT_REFS: tighten refs gate from openedPaths to readSet (read+preloaded only)
# CITING_REASONING: require scratchpad.refs_why[path] = "one-line reason" for every ref; harness rejects if missing or < 8 chars
# STRUCTURED_FACTS: typed slot store at scratchpad.facts[name] = {value, description, source, confidence}; sources auto-promote to refs at submit
# FEAT_REFS_WHY_CANONICAL: refs_why becomes the only citation channel.
#   - scratchpad.cite(path, reason) is the documented way to cite. Atomic — throws if reason < 8 chars or path not read.
#   - scratchpad.refs is a derived readonly mirror of Object.keys(scratchpad.refs_why) at submit.
#   - Auto-cite is disabled regardless of FEAT_AUTO_CITE.
# FEAT_DEBUG_REF_PROBE: diagnostic only. On submission, logs every on-disk path each cited .json resolves to
#   (a `ref_alias_probe` bootstrap event). Adds one find() RPC per cited .json per attempt — off by default.
# FEAT_NAV_HINTS: append the <navigation-hardening> prompt block (real SQL schema + "empty result is never proof
#   of absence", product-attribute matching, checkout UNSUPPORTED-vs-SECURITY, cite-what-you-derived). From the
#   2026-05-30 run-failure analysis; off by default so its grader impact can be A/B'd. Extended after the
#   100-task run (runs/20260530-110611) with dispatch-wave route/profit schema, always-cite subject+governing-doc,
#   positive-proof-before-ownership-refusal, and on_hand/available_today/incoming inventory semantics. See src/prompt.ts.
# Canonical names are FEAT_*. CITING_REASONING / STRUCTURED_FACTS above are accepted as back-compat aliases
#   for FEAT_CITING_REASONING / FEAT_STRUCTURED_FACTS (canonical wins if both set). Parsed in src/config.ts.
# REASONING_EFFORT: thinking effort for agent calls (low|medium|high|off); default medium. OpenRouter ignores on non-reasoning models.
FEAT_LAZY_MD=true
FEAT_AUTO_CITE=true
FEAT_STRICT_REFS=true
CITING_REASONING=true
STRUCTURED_FACTS=true
FEAT_REFS_WHY_CANONICAL=true
FEAT_DEBUG_REF_PROBE=true
FEAT_NAV_HINTS=false
REASONING_EFFORT=low
