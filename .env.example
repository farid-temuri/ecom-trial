# Required
OPENROUTER_API_KEY=
BITGN_API_KEY=

# Model & benchmark
MODEL_ID=z-ai/glm-5.1
# BENCH_ID=bitgn/ecom1-dev
# BITGN_HOST=https://api.bitgn.com

# Run control
MAX_TASKS=
CONCURRENCY=3
HINT=

# OpenRouter
OPENROUTER_TIMEOUT_MS=90000

# How long to wait for BitGN's grader after submitRun (ms). 5 min default.
SCORE_POLL_TIMEOUT_MS=300000

# Pre-submission LLM judge — set false to skip the judge gate
JUDGE_ENABLED=true
# Defaults to MODEL_ID if unset
JUDGE_MODEL=

# Web UI port, 0 to disable
WEB_PORT=3000
